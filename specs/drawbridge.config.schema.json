{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drawbridge.dev/schema/drawbridge.config.v1.json",
  "title": "Drawbridge configuration (v1)",
  "description": "The single source of truth for the shape of a Drawbridge config. Both implementations validate against this. additionalProperties is false throughout so typos fail fast.",
  "type": "object",
  "required": ["version", "platforms"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "description": "Config-format version. Unknown versions are rejected.",
      "const": 1
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeout_ms": { "$ref": "#/$defs/timeoutMs" }
      }
    },
    "platforms": {
      "type": "object",
      "minProperties": 1,
      "description": "Map of platform key -> platform. The key is the tool-name prefix.",
      "propertyNames": { "$ref": "#/$defs/identifier" },
      "additionalProperties": { "$ref": "#/$defs/platform" }
    },
    "raw_request": {
      "description": "[v2] Reserved escape hatch. In v1 it must be absent or, if present, explicitly disabled.",
      "type": "object",
      "required": ["enabled"],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "description": "v1: must be false (presence requires an explicit disable).",
          "const": false
        }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Lower-case snake identifier (platform keys, operation/param names)."
    },
    "envVar": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
      "description": "Environment variable name (conventionally upper-case)."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "description": "Request timeout in milliseconds."
    },
    "elementType": {
      "description": "Allowed array-element / leaf types.",
      "enum": ["string", "integer", "number", "boolean", "enum"]
    },
    "platform": {
      "type": "object",
      "required": ["base_url", "auth", "operations"],
      "additionalProperties": false,
      "properties": {
        "base_url": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(https?://|\\$\\{)[^@\\s]+$",
          "description": "Fixed host+base path. Must be http(s) (or start with ${ENV}); no inline userinfo (@) — credentials only via auth.*_env. Never model-controllable."
        },
        "timeout_ms": { "$ref": "#/$defs/timeoutMs" },
        "read_only": {
          "type": "boolean",
          "default": false,
          "description": "When true, non-GET operations are not generated as tools."
        },
        "headers": {
          "type": "object",
          "description": "Static request headers sent on every request (e.g. User-Agent, Accept). Config-only, never model-controllable; NOT for secrets — use auth.",
          "propertyNames": { "pattern": "^[A-Za-z0-9-]+$" },
          "additionalProperties": { "type": "string" }
        },
        "auth": { "$ref": "#/$defs/auth" },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/operation" }
        }
      }
    },
    "auth": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "description": "v1 supports bearer | header | basic. oauth is reserved for v2 and is intentionally not accepted here.",
      "properties": {
        "type": { "enum": ["bearer", "header", "basic"] },
        "secret_env": { "$ref": "#/$defs/envVar" },
        "name": { "type": "string", "pattern": "^[A-Za-z0-9-]+$", "description": "Header name (type=header). HTTP token chars only — no CR/LF/space." },
        "username_env": { "$ref": "#/$defs/envVar" },
        "password_env": { "$ref": "#/$defs/envVar" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "bearer" } } },
          "then": { "required": ["secret_env"], "properties": { "name": false, "username_env": false, "password_env": false } }
        },
        {
          "if": { "properties": { "type": { "const": "header" } } },
          "then": { "required": ["name", "secret_env"], "properties": { "username_env": false, "password_env": false } }
        },
        {
          "if": { "properties": { "type": { "const": "basic" } } },
          "then": { "required": ["username_env", "password_env"], "properties": { "secret_env": false, "name": false } }
        }
      ]
    },
    "operation": {
      "type": "object",
      "required": ["name", "description", "method", "path"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Required. Becomes the MCP tool description."
        },
        "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "timeout_ms": { "$ref": "#/$defs/timeoutMs" },
        "path": {
          "type": "string",
          "pattern": "^/(?![/\\\\]).*$",
          "description": "Host-relative path template with {name} placeholders bound to in:path params. Single leading slash only (no protocol-relative //host)."
        },
        "params": {
          "type": "array",
          "items": { "$ref": "#/$defs/param" }
        },
        "returns": {
          "description": "[v2] Field allowlist. Specced; not enforced in v1.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fields": { "type": "array", "items": { "type": "string" } }
          }
        },
        "max_response_bytes": {
          "type": "integer",
          "minimum": 1,
          "default": 1048576,
          "description": "Truncate responses larger than this (default 1 MiB)."
        }
      }
    },
    "param": {
      "type": "object",
      "required": ["name", "in", "type"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "in": { "enum": ["path", "query", "body"] },
        "type": { "enum": ["string", "integer", "number", "boolean", "enum", "array"] },
        "required": { "type": "boolean", "default": false },
        "description": { "type": "string" },
        "enum": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Allowed string values (type=enum)."
        },
        "default": {
          "description": "Default value when the param is omitted (any JSON value)."
        },
        "items": {
          "type": "object",
          "additionalProperties": false,
          "description": "Element schema (type=array). No nested arrays/objects in v1.",
          "required": ["type"],
          "properties": {
            "type": { "$ref": "#/$defs/elementType" },
            "enum": { "type": "array", "minItems": 1, "items": { "type": "string" } }
          },
          "allOf": [
            {
              "if": { "properties": { "type": { "const": "enum" } } },
              "then": { "required": ["enum"] }
            }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "enum" } } },
          "then": { "required": ["enum"] }
        },
        {
          "if": { "not": { "properties": { "type": { "const": "enum" } } } },
          "then": { "properties": { "enum": false } }
        },
        {
          "if": { "properties": { "type": { "const": "array" } } },
          "then": { "required": ["items"], "properties": { "in": { "enum": ["query", "body"] } } }
        },
        {
          "if": { "not": { "properties": { "type": { "const": "array" } } } },
          "then": { "properties": { "items": false } }
        }
      ]
    }
  }
}
